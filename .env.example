# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://zcybernews.com
NEXT_PUBLIC_SITE_NAME=ZCyberNews

# ─── Admin Panel Auth (NextAuth v5) ──────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://zcybernews.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password
# Preferred: use bcrypt hash instead of plaintext password
# Generate: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# ─── AI Text Generation ──────────────────────────────────────────────────────
AI_PROVIDER=deepseek          # deepseek | kimi | openai

DEEPSEEK_API_KEY=              # https://platform.deepseek.com
KIMI_API_KEY=                  # https://platform.moonshot.cn (Kimi K2)
OPENAI_API_KEY=                # fallback / DALL-E 3 images

# ─── Web Search Enrichment ───────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=          # https://api.search.brave.com
# or: TAVILY_API_KEY=

# ─── Image Generation (Phase 5) ──────────────────────────────────────────────
FAL_KEY=                       # https://fal.ai — FLUX.1-schnell ~$0.003/img

# ─── GitHub Publishing ───────────────────────────────────────────────────────
# Fine-grained personal access token with contents: write permission
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=jamesKhor/Zcybernews   # owner/repo
GITHUB_BRANCH=main

# ─── WeChat Integration ──────────────────────────────────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=                  # for webhook signature verification
WECHAT_AUTO_PUSH=false         # set true to auto-push drafts to Official Account

# ─── Ads / Monetization ──────────────────────────────────────────────────────
# Google AdSense — get your publisher ID at https://adsense.google.com
NEXT_PUBLIC_ADSENSE_ID=              # ca-pub-XXXXXXXXXXXXXXXX
# Ad slot IDs (create in AdSense dashboard → Ads → By ad unit)
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=    # 300x250 sidebar rectangle
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=    # in-article responsive banner
NEXT_PUBLIC_ADSENSE_SLOT_FEED=       # in-feed ad for listing pages

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
# Audience IDs — run `npx tsx scripts/setup-resend.ts` once to create & print these
RESEND_AUDIENCE_ID_EN=
RESEND_AUDIENCE_ID_ZH=
# From address must be on a verified domain in Resend
RESEND_FROM_EMAIL="ZCyberNews <news@zcybernews.com>"
RESEND_REPLY_TO=news@zcybernews.com

# ─── Notifications (Telegram) ────────────────────────────────────────────────
# Get bot token from @BotFather on Telegram, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=              # 123456:ABC-DEF...
TELEGRAM_CHAT_ID=                # your personal chat ID (number)

# ─── Community (Discord + WeChat) ────────────────────────────────────────────
# Discord webhooks — create in Server Settings → Integrations → Webhooks.
# Pipeline auto-posts every published article to the channel the webhook points to.
# If unset, Discord notifications are silently skipped.
DISCORD_WEBHOOK_EN=              # webhook URL for #en-news-feed channel
DISCORD_WEBHOOK_ZH=              # webhook URL for #zh-news-feed channel

# Public community links — shown on Footer + article end.
# If neither is set, the CommunityCTA component renders nothing.
# Server invite URL (keep this evergreen — never-expiring invite)
NEXT_PUBLIC_DISCORD_INVITE_URL=  # e.g. https://discord.gg/yourserver
# WeChat group QR code page (host your own static image, or use a link-in-bio service)
NEXT_PUBLIC_WECHAT_QR_URL=       # e.g. https://zcybernews.com/wechat-qr.png

# ─── Analytics ───────────────────────────────────────────────────────────────
# Plausible custom script URL (from your Plausible dashboard → Site Setup)
# e.g. https://plausible.io/js/pa-XXXXXXXXXXXX.js
NEXT_PUBLIC_PLAUSIBLE_SRC=

# ─── ISR Revalidation ────────────────────────────────────────────────────────
# Secret guarding /api/revalidate. Used by admin publish routes AND by the
# deploy-vps.yml content-only path to invalidate ISR caches without rebuild.
# Generate: openssl rand -base64 32
REVALIDATE_SECRET=

# ─── Deployment ──────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
